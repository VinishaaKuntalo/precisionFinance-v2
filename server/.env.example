PORT=3001
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_key
PLAID_ENV=sandbox
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# OAuth Redirect URI (REQUIRED for OAuth-only institutions like Wealthsimple)
# You MUST register this exact URI in your Plaid Dashboard:
#   Go to https://dashboard.plaid.com → API → OAuth → Add redirect URI
# For local development: http://localhost:3000
# For production: https://your-domain.com/
PLAID_REDIRECT_URI=http://localhost:3000

# Email (for password reset AND payment due-date reminders)
# If not set, emails are logged to the server console instead of sent
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@precisionfinance.app
FRONTEND_URL=http://localhost:3000

# Due-date reminder emails — sent automatically per-user (see docs/EMAIL_REMINDERS.md)
# CRON_SECRET protects POST /api/cron/check-reminders if you wire up an
# external scheduler. Required only if you use that route; the server also
# runs its own built-in check every REMINDER_CHECK_INTERVAL_MS regardless.
CRON_SECRET=generate_a_long_random_string
# Optional: override how often the built-in reminder check runs (ms).
# Default is 21600000 (6 hours). Set to 0 to disable the built-in scheduler
# entirely and rely only on an external cron hitting /api/cron/check-reminders.
REMINDER_CHECK_INTERVAL_MS=21600000
